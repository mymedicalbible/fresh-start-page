# Copy to `.env` or `.env.local` for local dev. Use the same project as `supabase link`
# (Settings → API: Project URL = VITE_SUPABASE_URL, anon public = VITE_SUPABASE_ANON_KEY).
# Production (Cloudflare Pages, etc.) must set the same two vars for the DB you `db push` to,
# or the app will call a different database than your migrations.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Plushie shop (`/app/plushies`): on by default. Set to false to disable token earns/RPCs,
# hide plushie navigation, and use a single optional mascot Lottie on the dashboard + account instead.
# Requires plushie migrations through at least `20260411120000_game_tokens_trial` and later rotation/catalog files.
# VITE_GAME_TOKENS_ENABLED=false

# When plushies are off: URL for one Lottie JSON (defaults to `/lottie/simple-mascot.json` in `public/`).
# VITE_SIMPLE_MASCOT_LOTTIE=/lottie/my-mascot.json
