# Authenticated Playwright tests read this file (gitignored). Easiest path:
#
# 1. Add SUPABASE_SERVICE_ROLE_KEY to root `.env` (Supabase → Settings → API → service_role).
# 2. Run `npm run test:e2e` — `scripts/ensure-playwright-smoke-user.mjs` creates/updates the
#    smoke user and writes PLAYWRIGHT_* here automatically.
#
# Or copy this file to `.env.playwright` and set email/password manually for a real user
# in the same project as VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY.
#
# `PLAYWRIGHT_BASE_URL` is optional (defaults to local Vite http://127.0.0.1:5173).
#
PLAYWRIGHT_SMOKE_EMAIL=
PLAYWRIGHT_SMOKE_PASSWORD=

# Optional: test a deployed build instead of local (must match Supabase project & valid credentials)
# PLAYWRIGHT_BASE_URL=https://your-deployment.example.com
