# Copy this file to `.env.playwright` (gitignored) so authenticated Playwright tests run.
# Use the same Supabase user as your app: `PLAYWRIGHT_BASE_URL` defaults to local Vite
# (`http://127.0.0.1:5173`); Playwright starts it automatically unless you already run `npm run dev`.
# Your root `.env` must define VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY.
#
#   cp .env.playwright.example .env.playwright
#
PLAYWRIGHT_SMOKE_EMAIL=
PLAYWRIGHT_SMOKE_PASSWORD=

# Optional: test a deployed build instead of local (must match Supabase project & valid credentials)
# PLAYWRIGHT_BASE_URL=https://your-deployment.example.com
