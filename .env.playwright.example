# Copy this file to `.env.playwright` (gitignored) so authenticated Playwright tests run.
# The app must be able to sign in this user against the project pointed to by PLAYWRIGHT_BASE_URL.
#
#   cp .env.playwright.example .env.playwright
#
PLAYWRIGHT_SMOKE_EMAIL=
PLAYWRIGHT_SMOKE_PASSWORD=

# Optional: point at local Vite (run `npm run dev` first)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
